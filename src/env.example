
# Path to the CSV dataset. Relative paths are resolved against the repo root
CSV_PATH=data/employees.csv

# Minimum group count required to return a real number instead of "suppressed"
SUPPRESSION_THRESHOLD=3

# Path where the JSONL audit log is written
AUDIT_LOG_PATH=logs/audit.log

# Restricted filters and group by fields
RESTRICTED_FIELDS=name,employee_id